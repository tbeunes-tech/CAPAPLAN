# Copier en .env et adapter. SQLite par défaut (dev) ; PostgreSQL en prod.
# DATABASE_URL=sqlite:///./portfolio.db
DATABASE_URL=postgresql+psycopg2://portfolio:portfolio@db:5432/portfolio

# Seuils de couleur du taux d'occupation (§5.5) — paramétrables.
OCCUPANCY_GREEN_BELOW=0.80
OCCUPANCY_AMBER_BELOW=1.00

# Auth §8.1 — OBLIGATOIRE en prod : générer une valeur aléatoire (openssl rand -hex 32).
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=480
